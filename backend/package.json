{
  "name": "providend-backend",
  "version": "1.0.0",
  "description": "Express TypeScript API for Providend assessment",
  "packageManager": "pnpm@9.15.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "pnpm exec jest --coverage",
    "test:watch": "pnpm exec jest --watch",
    "test:e2e": "pnpm exec jest --config jest.e2e.config.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "pg": "^8.13.0",
    "ioredis": "^5.4.1",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.6",
    "@types/cors": "^2.8.17",
    "jest": "^30.2.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3",
    "supertest": "^7.0.0"
  }
}
