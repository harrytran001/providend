{
  "name": "providend",
  "private": true,
  "description": "Providend full stack local dev – backend, frontend, Docker",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:backend": "pnpm --filter providend-backend dev",
    "dev:frontend": "pnpm --filter providend-frontend dev",
    "build:backend": "pnpm --filter providend-backend build",
    "build:frontend": "pnpm --filter providend-frontend build",
    "test:backend": "pnpm --filter providend-backend test",
    "test:e2e": "pnpm --filter providend-backend test:e2e",
    "start:backend": "pnpm --filter providend-backend start"
  }
}
